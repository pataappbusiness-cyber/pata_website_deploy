# Security Headers for pata.care - GitHub Pages
# Note: GitHub Pages has limited header support via _headers file
# For full security headers, consider Cloudflare, Netlify, or a custom server

/*
  # XSS Protection
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY

  # Referrer Policy
  Referrer-Policy: strict-origin-when-cross-origin

  # Permissions Policy - disable unused browser APIs
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()

  # HSTS - HTTP Strict Transport Security
  # Uncomment after confirming HTTPS works perfectly:
  # Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Cross-Origin-Opener-Policy
  Cross-Origin-Opener-Policy: same-origin

  # Content Security Policy
  # Start with report-only to test, then switch to enforcement
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://region1.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.bunny.net; img-src 'self' https://media.pata.care https://pata.care data: blob:; font-src 'self' https://fonts.bunny.net; media-src 'self' https://media.pata.care blob:; connect-src 'self' https://www.google-analytics.com https://region1.google-analytics.com https://analytics.google.com https://script.google.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://script.google.com; worker-src 'self' blob:

# Cache Control for static assets
/src/img/*
  Cache-Control: public, max-age=2592000, immutable

/src/css/dist/*
  Cache-Control: public, max-age=2592000, immutable

/src/js/dist/*
  Cache-Control: public, max-age=2592000, immutable

/src/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/*.html
  Cache-Control: public, max-age=3600, must-revalidate
